# Application
APP_ENV=production
APP_DEBUG=false
APP_URL=https://cie.yourcompany.com
INTERNAL_SERVICE_TOKEN=
# PHP → Python (G4 vector similarity, SKU suggest); align with Laravel config/services.php
PYTHON_WORKER_URL=http://localhost:8000
PYTHON_API_URL=http://localhost:8000
PYTHON_VECTOR_SIMILARITY_TIMEOUT_SECONDS=60

# Database
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=cie_v232
DB_USERNAME=cie_user
DB_PASSWORD=your_secure_password

# Redis (vector cache)
REDIS_URL=redis://localhost:6379/0

# OpenAI (embeddings + audit chat)
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_DIMENSIONS=

# === LOCAL LLM TESTING MODE (Python AI clients only) ===
# When true, routes OpenAI-compatible chat/embeddings and audit engines to LOCAL_LLM_BASE_URL.
# When false or unset, production cloud APIs are used unchanged.
#
# Base URL must include /v1 (OpenAI-compatible root). Typical ports:
# - LM Studio local server: http://localhost:1234/v1
# - Ollama OpenAI-compatible API: http://localhost:11434/v1
# - vLLM: http://localhost:8000/v1 (or your --port)
#
# --- Ollama (Windows) quick start ---
# 1) Install from https://ollama.com/download/windows (tray app / service).
# 2) Pull a model (pick size that fits RAM/VRAM; name must match env below):
#    ollama pull qwen2.5:7b-instruct-q4_K_M
# 3) Ollama listens on 11434 by default; no need for port 1234 unless you proxy.
# 4) Python FastAPI loads env from project root .env and/or backend/python/.env — set LOCAL_LLM_* where your workers run.
# 5) php artisan cie:vector-retry-process reads OPENAI_* / LOCAL_LLM_* via config/services.php — duplicate keys in backend/php/.env (Laravel .env), then php artisan config:clear (or config:cache after changes).
# Embeddings: chat models often lack /v1/embeddings; get_embedding may fall back to a mock vector (flow test only — not semantic).
#
LOCAL_LLM_MODE=false
LOCAL_LLM_BASE_URL=http://localhost:1234/v1
LOCAL_LLM_MODEL=llama-3.1-8b
AI_PROVIDER=local
#
# Uncomment and adjust model tag to match `ollama list` (example: Ollama + Qwen2.5 instruct):
# LOCAL_LLM_MODE=true
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# ANTHROPIC_API_KEY=ollama
# ANTHROPIC_MODEL=qwen2.5:7b-instruct-q4_K_M
# OPENAI_API_KEY=ollama
# OPENAI_EMBEDDING_MODEL=qwen2.5:7b-instruct-q4_K_M
# OPENAI_CHAT_MODEL=qwen2.5:7b-instruct-q4_K_M
# GEMINI_API_KEY=ollama
# GEMINI_MODEL=qwen2.5:7b-instruct-q4_K_M
# PERPLEXITY_API_KEY=ollama
# PERPLEXITY_MODEL=qwen2.5:7b-instruct-q4_K_M
#
# LM Studio / other servers on port 1234 (placeholders — use the model id your server exposes):
# LOCAL_LLM_MODE=true
# LOCAL_LLM_BASE_URL=http://localhost:1234/v1
# ANTHROPIC_API_KEY=local-dummy-key
# ANTHROPIC_MODEL=Qwen3-Next-dummy-Instruct-dummy
# OPENAI_API_KEY=local-dummy-key
# OPENAI_EMBEDDING_MODEL=Qwen3-Next-dummy-Instruct-dummy
# OPENAI_CHAT_MODEL=Qwen3-Next-dummy-Instruct-dummy
# GEMINI_API_KEY=local-dummy-key
# GEMINI_MODEL=Qwen3-Next-dummy-Instruct-dummy
# PERPLEXITY_API_KEY=local-dummy-key
# PERPLEXITY_MODEL=Qwen3-Next-dummy-Instruct-dummy

# AI Audit Engines
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro
ANTHROPIC_API_KEY=sk-ant-...
# SOURCE: CLAUDE.md §19 — model id (must match Anthropic API); Build Pack §4.2
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro

# ERP Integration
ERP_SYNC_ENABLED=true
ERP_SYNC_SCHEDULE=0 2 1 * *
# Connector type: "csv" (default), "rest", or "odbc"
ERP_CONNECTOR=csv

# CSV connector (drop ERP export CSVs into this directory)
ERP_CSV_DIRECTORY=storage/erp_imports
# Column rename map — CIE_field:CSV_header (only needed if CSV headers differ from defaults)
# ERP_CSV_COLUMN_MAP=sku_id:SKU Code,contribution_margin_pct:Margin%,cppc:CPPC,velocity_90d:Velocity90D,return_rate_pct:ReturnRate%

# REST connector (Method A — Direct API call)
# ERP_API_URL=https://erp.company.com/api/v1/products
# ERP_API_KEY=your_erp_api_key
# ERP_REST_SKU_PATH=data
# ERP_REST_FIELD_MAP=sku_id:item_code,cppc:cost_per_click

# ODBC connector (direct database)
# ERP_CONNECTION_STRING=Driver={SQL Server};Server=erp.company.com;Database=ProductDB;
# ERP_ODBC_QUERY=SELECT sku_id, contribution_margin_pct, cppc, velocity_90d, return_rate_pct FROM erp_sku_view
# ERP_ODBC_FIELD_MAP=sku_id:ItemCode

# Internal API key for Python → PHP calls (ERP sync, tier changes)
CIE_CMS_URL=http://localhost:8000
CIE_INTERNAL_API_KEY=

# Email/SMTP
MAIL_MAILER=smtp
MAIL_HOST=smtp.company.com
MAIL_PORT=587
MAIL_USERNAME=cie@company.com
MAIL_PASSWORD=...
MAIL_FROM_ADDRESS=cie@company.com
MAIL_FROM_NAME="CIE System"

# Vector Validation
# VECTOR_SIMILARITY_THRESHOLD / SIMILARITY_THRESHOLD: use business_rules key gates.vector_similarity_min (seed default in migrations — do not hard-code here)
VECTOR_SIMILARITY_THRESHOLD=0.72
EMBEDDING_TIMEOUT=3000  # milliseconds
VECTOR_CACHE_TTL=86400  # 24 hours

# Feature Flags
FAIL_SOFT_ENABLED=true
DECAY_MONITORING_ENABLED=true
AUTO_BRIEF_GENERATION=true

# Channel deploy (SOURCE: CLAUDE.md Section 19)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_PULL_ENABLED=true
N8N_WEBHOOK_SECRET=
# Google (GSC / GA4) — canonical names per CLAUDE.md §19
GOOGLE_SERVICE_ACCOUNT_JSON=
GSC_PROPERTY=https://www.example.com
GA4_PROPERTY_ID=
# SOURCE: CIE_Master_Developer_Build_Spec.docx §5.3 — mirror business_rules.sync.* for Python workers (see GAP_LOG GAP-P6-1)
SYNC_GSC_CRON_SCHEDULE=0 3 * * 0
SYNC_GA4_CRON_SCHEDULE=0 3 * * 1

# Logging
LOG_LEVEL=info
LOG_CHANNEL=stack
